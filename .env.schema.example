# .env.schema.example
#
# Copy this file to .env.schema and customize it for your project.
# This file defines the expected shape of your environment configuration.
#
# Format: VAR_NAME [required|optional] [type=TYPE] [default=VALUE] [desc=Description]
#
# Types:
#   string   - any non-empty string (default)
#   number   - any finite number
#   boolean  - true, false, 1, 0, yes, no
#   url      - http:// or https:// URLs only
#   port     - integer between 1 and 65535
#
# Examples:

DATABASE_URL required type=string desc=Primary database connection string
REDIS_URL optional type=string desc=Redis connection string (redis://host:port)

PORT optional type=port default=3000 desc=HTTP server port
HOST optional type=string default=0.0.0.0 desc=Server bind address

NODE_ENV required type=string desc=Runtime environment: development, staging, production
SECRET_KEY required type=string desc=Application secret for signing tokens and sessions

LOG_LEVEL optional type=string default=info desc=Logging verbosity: debug, info, warn, error
ENABLE_METRICS optional type=boolean default=false desc=Expose a /metrics endpoint
MAX_CONNECTIONS optional type=number default=10 desc=Database connection pool size

EXTERNAL_API_URL optional type=url desc=Third-party API base URL (https only)
